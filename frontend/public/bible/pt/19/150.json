{"book":"Salmos","chapter":150,"verses":[{"verse":1,"text":["> Louvem ao Senhor!","> Honrem a Deus em Seu lugar santo;","> Louvem-No em Seus vastos céus."]},{"verse":2,"text":["> Honrem-No por Seus atos poderosos;","> Louvem-No por Sua suprema grandeza."]},{"verse":3,"text":["> Honrem-No com o som da trombeta;","> Louvem-No com harpa e lira."]},{"verse":4,"text":["> Honrem-No com tamborim e dança;","> Louvem-No com instrumentos de cordas e flauta."]},{"verse":5,"text":["> Honrem-No com címbalos sonoros;","> Louvem-No com címbalos retumbantes."]},{"verse":6,"text":["> Tudo o que tem fôlego, louve ao Senhor.","> Louvem ao Senhor!"]}]}